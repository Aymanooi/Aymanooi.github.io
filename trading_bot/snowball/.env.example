# ════════════════════════════════════════════════════════════════
#  انسخ هذا الملف إلى .env  ثم ضع مفاتيحك الحقيقية
#  cp .env.example .env
#  ⚠️ لا ترفع ملف .env إلى GitHub أبداً (محمي عبر .gitignore)
# ════════════════════════════════════════════════════════════════

# ── مفاتيح OKX (من Account > API) ──
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ── OpenRouter (لمجلس الذكاء الاصطناعي) ──
OPENROUTER_API_KEY=

# ── Telegram (اختياري — للإشعارات) ──
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
